<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>CodeVault — Free Python Snippets</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#060608;
  --bg2:#0a0b0f;
  --bg3:#0f1117;
  --card:#111318;
  --card2:#161820;
  --border:#1e2130;
  --border2:#2a2f45;
  --green:#00ff88;
  --green2:#00cc6a;
  --cyan:#00e5ff;
  --amber:#ffb700;
  --rose:#ff4d6d;
  --violet:#9d7fff;
  --text:#e8eaf2;
  --text2:#8892aa;
  --text3:#3d4560;
  --mono:'Space Mono',monospace;
  --sans:'Outfit',sans-serif;
  --glow-green:0 0 40px rgba(0,255,136,.15);
  --glow-cyan:0 0 40px rgba(0,229,255,.12);
}

html{scroll-behavior:smooth}
body{
  font-family:var(--sans);
  background:var(--bg);
  color:var(--text);
  min-height:100vh;
  overflow-x:hidden;
  cursor:none;
}

/* ── CURSOR ── */
#cursor{
  position:fixed;width:10px;height:10px;border-radius:50%;
  background:var(--green);pointer-events:none;z-index:9999;
  transition:transform .1s;box-shadow:0 0 12px var(--green);
  transform:translate(-50%,-50%);
}
#cursor-ring{
  position:fixed;width:32px;height:32px;border-radius:50%;
  border:1px solid rgba(0,255,136,.4);pointer-events:none;z-index:9998;
  transform:translate(-50%,-50%);transition:all .18s ease;
}

/* ── SCANLINES ── */
body::after{
  content:'';position:fixed;inset:0;z-index:1;pointer-events:none;
  background:repeating-linear-gradient(
    0deg,transparent,transparent 2px,rgba(0,0,0,.03) 2px,rgba(0,0,0,.03) 4px
  );
}

/* ── NOISE OVERLAY ── */
body::before{
  content:'';position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.025;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
}

/* ── GRID BG ── */
.grid-bg{
  position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:
    linear-gradient(rgba(0,255,136,.018) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,255,136,.018) 1px,transparent 1px);
  background-size:60px 60px;
}

/* ── GLOW ORBS ── */
.orb{position:fixed;border-radius:50%;pointer-events:none;z-index:0;filter:blur(100px)}
.orb1{width:700px;height:700px;background:radial-gradient(circle,rgba(0,255,136,.06) 0%,transparent 70%);top:-300px;left:-200px}
.orb2{width:500px;height:500px;background:radial-gradient(circle,rgba(0,229,255,.05) 0%,transparent 70%);bottom:-200px;right:-100px}

/* ── HEADER ── */
header{
  position:sticky;top:0;z-index:500;
  background:rgba(6,6,8,.92);
  backdrop-filter:blur(24px) saturate(180%);
  border-bottom:1px solid var(--border);
  padding:0 48px;height:64px;
  display:flex;align-items:center;justify-content:space-between;
}
.logo{
  display:flex;align-items:center;gap:14px;
  font-family:var(--mono);font-size:15px;font-weight:700;
  color:var(--text);letter-spacing:-0.5px;
}
.logo-icon{
  width:36px;height:36px;border-radius:8px;
  border:1.5px solid var(--green);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--mono);font-size:12px;color:var(--green);font-weight:700;
  box-shadow:0 0 14px rgba(0,255,136,.2);
  flex-shrink:0;background:rgba(0,255,136,.06);
}
.logo-text em{color:var(--green);font-style:normal}

nav{display:flex;gap:2px}
nav a{
  font-family:var(--mono);font-size:11px;
  color:var(--text2);padding:6px 14px;border-radius:6px;
  text-decoration:none;transition:all .2s;letter-spacing:.5px;
  text-transform:uppercase;
}
nav a:hover{color:var(--green);background:rgba(0,255,136,.06)}
nav a.active{color:var(--green)}

.header-badge{
  font-family:var(--mono);font-size:10px;
  border:1px solid rgba(0,255,136,.25);
  background:rgba(0,255,136,.05);
  color:var(--green);padding:5px 14px;border-radius:20px;
  letter-spacing:1px;text-transform:uppercase;
  display:flex;align-items:center;gap:7px;
}
.live-dot{
  width:6px;height:6px;border-radius:50%;
  background:var(--green);box-shadow:0 0 8px var(--green);
  animation:blink 2s ease-in-out infinite;
}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

/* ── HERO ── */
.hero{
  position:relative;z-index:1;
  padding:120px 48px 80px;
  max-width:1200px;margin:0 auto;
}
.hero-eyebrow{
  font-family:var(--mono);font-size:11px;
  color:var(--green);letter-spacing:3px;text-transform:uppercase;
  margin-bottom:24px;display:flex;align-items:center;gap:10px;
}
.hero-eyebrow::before{
  content:'';display:block;width:40px;height:1px;background:var(--green);
  box-shadow:0 0 8px var(--green);
}
.hero h1{
  font-family:var(--sans);font-weight:900;
  font-size:clamp(48px,7vw,96px);
  line-height:.95;letter-spacing:-4px;
  color:var(--text);margin-bottom:32px;
}
.hero h1 .line2{
  display:block;
  background:linear-gradient(90deg,var(--green) 0%,var(--cyan) 60%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.hero-desc{
  max-width:560px;color:var(--text2);
  font-size:16px;line-height:1.8;margin-bottom:48px;
  font-weight:400;
}
.hero-desc strong{color:var(--green);font-weight:600}

.hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:64px}
.btn{
  display:inline-flex;align-items:center;gap:8px;
  padding:13px 28px;border-radius:10px;
  font-family:var(--mono);font-size:12px;font-weight:700;
  letter-spacing:.5px;text-transform:uppercase;
  cursor:none;transition:all .25s;text-decoration:none;border:none;
}
.btn-primary{
  background:var(--green);color:#000;
  box-shadow:0 4px 28px rgba(0,255,136,.3);
}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 40px rgba(0,255,136,.45)}
.btn-secondary{
  background:transparent;color:var(--text2);
  border:1px solid var(--border2);
}
.btn-secondary:hover{border-color:var(--green);color:var(--green);transform:translateY(-2px)}

.hero-stats{
  display:flex;gap:0;
  border:1px solid var(--border);border-radius:14px;
  background:var(--card);overflow:hidden;
  width:fit-content;
}
.stat{
  padding:20px 36px;text-align:center;
  border-right:1px solid var(--border);
}
.stat:last-child{border-right:none}
.stat-val{font-family:var(--mono);font-size:26px;font-weight:700;color:var(--text)}
.stat-val span{color:var(--green)}
.stat-lbl{font-family:var(--mono);font-size:10px;color:var(--text3);margin-top:4px;letter-spacing:1px;text-transform:uppercase}

/* ── MARQUEE ── */
.marquee-wrap{
  position:relative;z-index:1;
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
  background:var(--bg2);
  padding:12px 0;overflow:hidden;
}
.marquee-track{
  display:flex;width:max-content;
  animation:slide 30s linear infinite;
}
@keyframes slide{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.m-item{
  display:inline-flex;align-items:center;gap:8px;
  padding:0 28px;border-right:1px solid var(--border);
  font-family:var(--mono);font-size:10px;letter-spacing:1px;
  color:var(--text3);text-transform:uppercase;white-space:nowrap;
}
.m-dot{width:4px;height:4px;border-radius:50%;flex-shrink:0}

/* ── SECTION ── */
.section{
  position:relative;z-index:1;
  max-width:1200px;margin:0 auto;
  padding:80px 48px;
}
.section-header{
  display:flex;align-items:center;gap:16px;
  margin-bottom:48px;
}
.section-tag{
  font-family:var(--mono);font-size:10px;
  color:var(--green);letter-spacing:2px;text-transform:uppercase;
  border:1px solid rgba(0,255,136,.2);
  background:rgba(0,255,136,.04);
  padding:4px 12px;border-radius:4px;
}
.section-title{
  font-size:28px;font-weight:800;color:var(--text);
  letter-spacing:-1px;
}

/* ── SNIPPET GRID ── */
.snippets-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(420px,1fr));
  gap:20px;
}

/* ── SNIPPET CARD ── */
.card{
  background:var(--card);border:1px solid var(--border);
  border-radius:14px;overflow:hidden;
  transition:transform .3s,border-color .3s,box-shadow .3s;
  display:flex;flex-direction:column;
  animation:fadeUp .5s ease both;
}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.card:hover{
  transform:translateY(-4px);
  border-color:var(--border2);
  box-shadow:0 20px 60px rgba(0,0,0,.5),var(--glow-green);
}
.card-stripe{height:2px}
.stripe-green{background:linear-gradient(90deg,var(--green),var(--cyan))}
.stripe-amber{background:linear-gradient(90deg,var(--amber),var(--rose))}
.stripe-violet{background:linear-gradient(90deg,var(--violet),var(--cyan))}
.stripe-rose{background:linear-gradient(90deg,var(--rose),var(--violet))}

.card-top{
  padding:18px 20px 14px;
  display:flex;align-items:flex-start;justify-content:space-between;gap:12px;
}
.card-labels{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px}
.label{
  font-family:var(--mono);font-size:9px;font-weight:700;
  padding:3px 9px;border-radius:3px;letter-spacing:.5px;text-transform:uppercase;
}
.label-green{background:rgba(0,255,136,.1);color:var(--green);border:1px solid rgba(0,255,136,.2)}
.label-cyan{background:rgba(0,229,255,.1);color:var(--cyan);border:1px solid rgba(0,229,255,.2)}
.label-amber{background:rgba(255,183,0,.1);color:var(--amber);border:1px solid rgba(255,183,0,.2)}
.label-violet{background:rgba(157,127,255,.1);color:var(--violet);border:1px solid rgba(157,127,255,.2)}
.label-rose{background:rgba(255,77,109,.1);color:var(--rose);border:1px solid rgba(255,77,109,.2)}

.card-title{
  font-size:15px;font-weight:700;color:var(--text);
  line-height:1.35;margin-bottom:6px;
}
.card-desc{font-size:12px;color:var(--text2);line-height:1.6}
.card-emoji{
  font-size:22px;width:44px;height:44px;
  border-radius:10px;background:rgba(0,255,136,.08);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}

/* ── CODE WINDOW ── */
.code-window{
  margin:0 16px 0;border-radius:10px;
  overflow:hidden;border:1px solid var(--border);
}
.code-bar{
  background:#0a0b0f;padding:8px 14px;
  display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid var(--border);
}
.code-dots{display:flex;gap:5px}
.cd{width:9px;height:9px;border-radius:50%}
.cd-r{background:#ff5f57}.cd-y{background:#febc2e}.cd-g{background:#28c840}
.code-fname{font-family:var(--mono);font-size:10px;color:var(--text3);letter-spacing:.5px}
.code-lang{
  font-family:var(--mono);font-size:9px;font-weight:700;
  padding:2px 8px;border-radius:3px;
  background:rgba(0,255,136,.1);color:var(--green);letter-spacing:.5px;
}
pre.snippet{
  margin:0 !important;
  background:#080a0e !important;
  font-family:var(--mono) !important;
  font-size:11.5px !important;
  line-height:1.75 !important;
  padding:14px 16px !important;
  max-height:200px;
  overflow-y:auto !important;
  color:#c9d1e0 !important;
  border-radius:0 !important;
}
pre.snippet::-webkit-scrollbar{width:3px;height:3px}
pre.snippet::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

/* syntax colors */
.kw{color:#ff7eb3}
.fn{color:#82cfff}
.st{color:#a8e6a3}
.cm{color:#546e7a;font-style:italic}
.nm{color:#ffcb6b}
.op{color:#89ddff}
.df{color:var(--green)}

/* ── CARD FOOTER ── */
.card-foot{
  padding:12px 20px 16px;margin-top:auto;
  border-top:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:8px;
}
.card-meta{
  font-family:var(--mono);font-size:10px;
  color:var(--text3);display:flex;align-items:center;gap:12px;
}
.copy-code-btn{
  display:inline-flex;align-items:center;gap:6px;
  font-family:var(--mono);font-size:10px;font-weight:700;
  padding:7px 16px;border-radius:7px;letter-spacing:.5px;
  border:1px solid rgba(0,255,136,.25);
  background:rgba(0,255,136,.06);color:var(--green);
  cursor:none;transition:all .2s;text-transform:uppercase;
}
.copy-code-btn:hover{background:var(--green);color:#000;box-shadow:0 4px 20px rgba(0,255,136,.3)}
.copy-code-btn.copied{background:rgba(0,229,255,.1);border-color:rgba(0,229,255,.3);color:var(--cyan)}

/* ── FULL POST VIEW ── */
.post-overlay{
  position:fixed;inset:0;z-index:1000;
  background:rgba(0,0,0,.88);backdrop-filter:blur(12px);
  display:flex;align-items:flex-start;justify-content:center;
  padding:32px 24px;overflow-y:auto;
  opacity:0;pointer-events:none;transition:opacity .3s;
}
.post-overlay.open{opacity:1;pointer-events:all}
.post-modal{
  background:var(--card2);
  border:1px solid var(--border2);
  border-radius:18px;width:100%;max-width:820px;
  overflow:hidden;
  transform:translateY(24px) scale(.97);
  transition:transform .3s;
}
.post-overlay.open .post-modal{transform:translateY(0) scale(1)}
.modal-head{
  padding:24px 28px 18px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:flex-start;justify-content:space-between;gap:16px;
}
.modal-labels{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px}
.modal-title{font-size:20px;font-weight:800;color:var(--text);line-height:1.3;letter-spacing:-.5px}
.modal-meta{font-family:var(--mono);font-size:10px;color:var(--text3);margin-top:6px;letter-spacing:.5px}
.modal-close{
  width:34px;height:34px;border-radius:8px;flex-shrink:0;
  background:var(--card);border:1px solid var(--border);
  color:var(--text2);cursor:none;font-size:16px;
  display:flex;align-items:center;justify-content:center;
  transition:all .2s;
}
.modal-close:hover{color:var(--rose);border-color:var(--rose)}
.modal-body{padding:28px;overflow-y:auto;max-height:70vh}

/* post content styles */
.post-body h2{
  font-size:16px;font-weight:800;color:var(--text);
  margin:28px 0 10px;padding-left:12px;
  border-left:2px solid var(--green);
  letter-spacing:-.3px;
}
.post-body h3{
  font-family:var(--mono);font-size:12px;font-weight:700;
  color:var(--cyan);margin:20px 0 8px;letter-spacing:.5px;text-transform:uppercase;
}
.post-body p{
  color:var(--text2);font-size:14px;line-height:1.85;margin-bottom:14px;
}
.post-body strong{color:var(--green);font-weight:600}
.post-body ul{
  color:var(--text2);font-size:14px;padding-left:20px;
  margin-bottom:14px;line-height:1.85;
}
.post-body li{margin-bottom:6px}
.post-body blockquote{
  border-left:2px solid var(--amber);
  background:rgba(255,183,0,.05);
  padding:12px 16px;border-radius:0 8px 8px 0;
  margin:16px 0;color:var(--text2);font-size:13px;
  font-family:var(--mono);
}
.post-body pre{
  background:#060810 !important;
  border:1px solid var(--border);
  border-radius:10px;overflow:auto;
  padding:18px 20px !important;margin:16px 0 !important;
  position:relative;
  font-family:var(--mono) !important;
  font-size:12.5px !important;line-height:1.75 !important;
  color:#c9d1e0 !important;
  box-shadow:0 8px 32px rgba(0,0,0,.4);
}
.copy-all-btn{
  display:flex;align-items:center;gap:8px;
  font-family:var(--mono);font-size:10px;font-weight:700;
  padding:9px 20px;border-radius:8px;text-transform:uppercase;letter-spacing:.5px;
  border:1px solid rgba(0,255,136,.25);
  background:rgba(0,255,136,.06);color:var(--green);
  cursor:none;transition:all .2s;margin-bottom:24px;
}
.copy-all-btn:hover{background:var(--green);color:#000}
.back-btn{
  display:inline-flex;align-items:center;gap:7px;
  font-family:var(--mono);font-size:10px;
  color:var(--text2);padding:8px 16px;border-radius:7px;
  border:1px solid var(--border);cursor:none;
  transition:all .2s;text-transform:uppercase;letter-spacing:.5px;
  background:transparent;margin-top:24px;
}
.back-btn:hover{color:var(--green);border-color:rgba(0,255,136,.3)}

/* ── HOW TO USE SECTION ── */
.how-section{
  position:relative;z-index:1;
  border-top:1px solid var(--border);
  background:var(--bg2);
  padding:80px 48px;
}
.how-inner{max-width:1200px;margin:0 auto}
.steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px;margin-top:48px}
.step{
  background:var(--card);border:1px solid var(--border);
  border-radius:12px;padding:24px;
  transition:border-color .3s;
}
.step:hover{border-color:var(--border2)}
.step-num{
  font-family:var(--mono);font-size:11px;font-weight:700;
  color:var(--green);margin-bottom:12px;
  letter-spacing:1px;display:flex;align-items:center;gap:8px;
}
.step-num::before{
  content:'';display:block;width:20px;height:1px;
  background:var(--green);box-shadow:0 0 6px var(--green);
}
.step h3{font-size:15px;font-weight:700;color:var(--text);margin-bottom:8px}
.step p{font-size:12px;color:var(--text2);line-height:1.7}

/* ── ABOUT BLOGGER SECTION ── */
.info-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:48px;
}
.info-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:12px;padding:24px;
}
.info-card h3{
  font-family:var(--mono);font-size:12px;font-weight:700;
  color:var(--green);letter-spacing:1px;text-transform:uppercase;
  margin-bottom:14px;
}
.info-card ul{list-style:none;display:flex;flex-direction:column;gap:8px}
.info-card ul li{
  font-size:13px;color:var(--text2);
  display:flex;align-items:flex-start;gap:8px;line-height:1.6;
}
.info-card ul li::before{
  content:'›';color:var(--green);font-family:var(--mono);
  font-weight:700;flex-shrink:0;margin-top:1px;
}

/* ── FOOTER ── */
footer{
  position:relative;z-index:1;
  border-top:1px solid var(--border);
  background:var(--bg2);padding:48px 48px 28px;
}
.footer-inner{max-width:1200px;margin:0 auto}
.footer-grid{
  display:grid;grid-template-columns:1.8fr 1fr 1fr 1fr;
  gap:40px;margin-bottom:40px;
}
.footer-brand p{font-size:13px;color:var(--text2);line-height:1.7;margin-top:14px;max-width:300px}
.footer-col h4{
  font-family:var(--mono);font-size:10px;font-weight:700;
  letter-spacing:1.5px;text-transform:uppercase;
  color:var(--text3);margin-bottom:14px;
}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:9px}
.footer-col ul li a{
  font-size:13px;color:var(--text2);text-decoration:none;
  transition:color .2s;font-family:var(--mono);font-size:11px;
}
.footer-col ul li a:hover{color:var(--green)}
.footer-bottom{
  border-top:1px solid var(--border);padding-top:22px;
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:12px;
}
.footer-bottom p{font-family:var(--mono);font-size:10px;color:var(--text3);letter-spacing:.5px}

/* ── SEARCH ENGINE ── */
.search-wrap{
  position:relative;z-index:1;
  max-width:1200px;margin:0 auto;
  padding:0 48px 48px;
}
.search-box{
  position:relative;display:flex;align-items:center;
}
.search-icon{
  position:absolute;left:18px;
  color:var(--text3);pointer-events:none;
